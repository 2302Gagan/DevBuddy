# ── AI backend selector ────────────────────────────────────────────────────────
# Set to "azure" to use Azure AI Foundry (Phi-4), or "copilot" for GitHub Models
NEXT_PUBLIC_AI_BACKEND=copilot

# ── GitHub Models ──────────────────────
# Requires a fine-grained PAT with "Models: Read" permission
# Create at: https://github.com/settings/tokens?type=beta
#   → Repository access: Public Repositories (read-only)
#   → Permissions → Account permissions → Models → Read
GITHUB_COPILOT_API_KEY=your_fine_grained_github_pat_here
COPILOT_API_URL=https://models.inference.ai.azure.com/chat/completions
# COPILOT_MODEL=gpt-4o

# ── Azure AI Foundry — Phi-4 ───────────────
# Create a project at: https://ai.azure.com
# Deploy Phi-4 via Models > phi-4 > Deploy > Serverless API
# Then copy the endpoint + key from the deployment detail page.
#
# Endpoint: copy the "Target URI" from your deployment page, append /openai/v1
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
#
# Deployment name — must match what you named it in Azure AI Foundry (default: Phi-4)
AZURE_FOUNDRY_DEPLOYMENT=Phi-4
#
# Auth uses DefaultAzureCredential — no API key needed.
# For local dev, run: az login
# For CI/production, set AZURE_CLIENT_ID + AZURE_CLIENT_SECRET + AZURE_TENANT_ID
#
# Optional: cap output length (default 4096, max 8192)
# PHI4_MAX_TOKENS=4096


# Optional: enables server-side GitHub Gist export
# Requires gist scope on the token
GITHUB_GIST_TOKEN=your_github_token_with_gist_scope

